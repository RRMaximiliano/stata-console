{
  "name": "stata-console",
  "displayName": "Stata Console",
  "description": "Interactive Stata console embedded in VS Code — terminal, data viewer, variables panel, plots",
  "version": "0.3.2",
  "publisher": "rrmaximiliano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RRMaximiliano/stata-console"
  },
  "homepage": "https://github.com/RRMaximiliano/stata-console#readme",
  "bugs": {
    "url": "https://github.com/RRMaximiliano/stata-console/issues"
  },
  "icon": "resources/icon.png",
  "keywords": [
    "stata",
    "econometrics",
    "statistics",
    "data-analysis",
    "do-file"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:stata",
    "onCommand:stata.openConsole"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stata-explorer",
          "title": "Stata",
          "icon": "resources/stata-icon.svg"
        }
      ]
    },
    "views": {
      "stata-explorer": [
        {
          "id": "stataDataset",
          "name": "Data"
        },
        {
          "id": "stataVariables",
          "name": "Variables"
        },
        {
          "id": "stataStoredResults",
          "name": "Stored Results"
        },
        {
          "id": "stataPlotsList",
          "name": "Plots"
        }
      ]
    },
    "grammars": [
      {
        "language": "stata",
        "scopeName": "source.stata",
        "path": "./syntaxes/stata.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "stata",
        "path": "./snippets/stata.json"
      }
    ],
    "commands": [
      {
        "command": "stata.openConsole",
        "title": "Open Stata Console",
        "category": "Stata"
      },
      {
        "command": "stata.run",
        "title": "Run Selection or Do-file",
        "category": "Stata"
      },
      {
        "command": "stata.runSelection",
        "title": "Run Selection/Line",
        "category": "Stata"
      },
      {
        "command": "stata.runFile",
        "title": "Run Current File",
        "category": "Stata"
      },
      {
        "command": "stata.clearConsole",
        "title": "Clear Console",
        "category": "Stata"
      },
      {
        "command": "stata.restartStata",
        "title": "Restart Stata",
        "category": "Stata"
      },
      {
        "command": "stata.diagnosePath",
        "title": "Diagnose Stata Path Detection",
        "category": "Stata"
      },
      {
        "command": "stata.browse",
        "title": "Browse Data",
        "category": "Stata",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.insertVariable",
        "title": "Insert Variable Name",
        "category": "Stata"
      },
      {
        "command": "stata.plotPrev",
        "title": "Previous Plot",
        "category": "Stata",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.plotNext",
        "title": "Next Plot",
        "category": "Stata",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.plotSave",
        "title": "Save Plot As...",
        "category": "Stata",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.showPlot",
        "title": "Show Plot",
        "category": "Stata"
      },
      {
        "command": "stata.plotClear",
        "title": "Clear All Plots",
        "category": "Stata",
        "icon": "$(trash)",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.refreshVariables",
        "title": "Refresh Variables",
        "category": "Stata",
        "icon": "$(refresh)",
        "enablement": "stata.consoleActive"
      },
      {
        "command": "stata.previewSthlp",
        "title": "Preview Stata Help File",
        "category": "Stata",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "stata.refreshVariables",
          "when": "view == stataVariables",
          "group": "navigation"
        },
        {
          "command": "stata.plotClear",
          "when": "view == stataPlotsList",
          "group": "navigation"
        },
        {
          "command": "stata.browse",
          "when": "view == stataDataset",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "stata.previewSthlp",
          "when": "resourceExtname == .sthlp",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "stata.runSelection",
          "when": "editorTextFocus && resourceExtname =~ /\\.(do|ado|mata)$/",
          "group": "stata@1"
        },
        {
          "command": "stata.run",
          "when": "editorTextFocus && resourceExtname =~ /\\.(do|ado|mata)$/",
          "group": "stata@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "stata.run",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus && resourceExtname =~ /\\.(do|ado|mata)$/"
      },
      {
        "command": "stata.runSelection",
        "key": "shift+enter",
        "mac": "shift+enter",
        "when": "editorTextFocus && editorLangId == stata"
      },
      {
        "command": "stata.clearConsole",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "terminalFocus"
      },
      {
        "command": "stata.previewSthlp",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus && resourceExtname == .sthlp"
      }
    ],
    "languages": [
      {
        "id": "stata",
        "aliases": [
          "Stata",
          "stata"
        ],
        "extensions": [
          ".do",
          ".ado",
          ".mata",
          ".sthlp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Stata Console",
      "properties": {
        "stata.stataPath": {
          "type": "string",
          "default": "",
          "description": "Full path to the Stata executable. Leave empty for auto-detection."
        },
        "stata.stataEdition": {
          "type": "string",
          "default": "MP",
          "enum": [
            "MP",
            "SE",
            "BE"
          ],
          "enumDescriptions": [
            "Stata/MP — Multiprocessor (fastest, requires license)",
            "Stata/SE — Standard Edition",
            "Stata/BE — Basic Edition"
          ],
          "description": "Which Stata edition to use. Auto-detection will prefer this edition."
        },
        "stata.browseRowLimit": {
          "type": "number",
          "default": 10000,
          "description": "Maximum number of observations to display in the Data Viewer."
        },
        "stata.colors.prompt": {
          "type": "string",
          "default": "#4E9A6A",
          "description": "Color of the \". \" prompt in the Stata console (hex)."
        },
        "stata.colors.command": {
          "type": "string",
          "default": "#569CD6",
          "description": "Color of echoed commands in the Stata console (hex)."
        },
        "stata.colors.error": {
          "type": "string",
          "default": "#CC3E44",
          "description": "Color of error messages in the Stata console (hex)."
        },
        "stata.colors.tableSeparator": {
          "type": "string",
          "default": "#B4B4B4",
          "description": "Color of table separator lines (---+---) in the Stata console (hex)."
        },
        "stata.colors.dim": {
          "type": "string",
          "default": "#787878",
          "description": "Color of dimmed/info text in the Stata console (hex)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npm run compile && node --test test/**/*.test.js",
    "verify": "npm run lint && npm run test && npm run compile",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0"
  }
}
